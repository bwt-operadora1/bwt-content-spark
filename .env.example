# Google Gemini API Key (PDF parsing + marketing content generation)
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=sua_chave_aqui

# Pexels API Key (fotos reais de destinos nas lâminas e vídeos)
